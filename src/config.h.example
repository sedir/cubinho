#pragma once

// =============================================================================
// CONFIGURAÇÃO DO PORTELA — M5 CoreS3
// Copie este arquivo para config.h e preencha com seus dados reais.
// config.h está no .gitignore para proteger suas credenciais.
// =============================================================================

// WiFi
// As credenciais sao configuradas no portal cativo e salvas em NVS.
// WIFI_KEEP_ALIVE define apenas o comportamento padrao apos conectar.
#define WIFI_KEEP_ALIVE  false

// Localização para OpenMeteo (ajuste para sua cidade)
#define GEO_LATITUDE         36.3938
#define GEO_LONGITUDE       136.4452
#define TIMEZONE_OFFSET_SEC  32400   // UTC+9 (JST) — UTC+0=0, UTC-3=-10800, UTC+9=32400

// Nome da cidade exibido na tela de clima
#define CITY_NAME "Komatsu, Ishikawa"

// Calendario pessoal (opcional)
// Use como fallback/default para o feed iCal/ICS.
// Tambem pode ser configurado depois pela tela "Configurar iCal".
// Ex.: Google/Apple/Outlook com feed "secret/private".
// Deixe vazio para desativar.
#define CALENDAR_ICS_URL ""

// NTP — servidores de tempo
#define NTP_SERVER_1 "ntp.nict.jp"
#define NTP_SERVER_2 "pool.ntp.org"

// Limites de conforto térmico — usado na tela de clima para colorir temperatura
#define COMFORT_TEMP_MIN  18.0f
#define COMFORT_TEMP_MAX  26.0f
#define COMFORT_HUM_MIN   40.0f
#define COMFORT_HUM_MAX   70.0f

// Intervalos de atualização
#define WEATHER_UPDATE_INTERVAL_MS  (30UL * 60UL * 1000UL)  // 30 minutos

// Gerenciamento de energia — brilho do display
#define BRIGHTNESS_ACTIVE  150    // brilho normal (0–255)
#define BRIGHTNESS_DIM      50    // brilho reduzido após inatividade (0–255)
#define BRIGHTNESS_MIN_FLOOR 80   // piso absoluto para auto-brilho/fade
#define BRIGHTNESS_FADE_STEP 2    // unidades por tick do fade
#define BRIGHTNESS_FADE_INTERVAL_MS 20
#define DIM_TIMEOUT_MS   30000    // ms sem toque → dim automático

// Auto-brilho via sensor de luz LTR553 (sensor embutido)
#define AUTO_BRIGHTNESS_ENABLED  true
#define AUTO_BRIGHTNESS_MIN       BRIGHTNESS_MIN_FLOOR
#define AUTO_BRIGHTNESS_MAX      200   // brilho máximo auto (0–255)

// Deep sleep — ativa após este tempo sem toque (timer não pode estar ativo)
#define DEEP_SLEEP_TIMEOUT_MS  (10UL * 60UL * 1000UL)  // 10 minutos

// GPIO do pino INT do touch FT6336U — acorda do deep sleep por toque
#define DEEP_SLEEP_WAKEUP_GPIO  21

// Sensor de proximidade LTR553 — threshold para acordar o display do dim
#define LTR553_PROX_THRESH  80

// Wake por acelerometro enquanto o display esta em dim
#define ACCEL_WAKE_ENABLED   true
#define ACCEL_WAKE_THRESHOLD 0.18f

// OTA — atualização sem fio (ativo apenas quando WiFi mantido por Telnet)
#define OTA_ENABLED  true
#define OTA_HOSTNAME "cubinho"

// Timers de cozinha — número máximo de timers simultâneos
#define MAX_TIMERS  3

// Portal cativo WiFi — entra em modo AP para configuração após N falhas
#define WIFI_PORTAL_FAIL_THRESHOLD  3
#define WIFI_PORTAL_AP_NAME         "Cubinho-Setup"

// Debug — log verboso do parsing iCal (desative em produção)
#define CALENDAR_DEBUG  false
